def adicionar_despesa():
    print("\n===== DESPESA =====")
    tipo = input("Tipo (fixa/variável): ")
    valor = ler_numero("Valor: R$ ")
    categoria = input("Categoria: ")

    supabase.table("despesas").insert({
        "tipo": tipo,
        "valor": valor,
        "categoria": categoria
