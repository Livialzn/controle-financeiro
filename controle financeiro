def adicionar_receita():
    print("\n===== RECEITA =====")
    tipo = input("Tipo (salário/extra): ")
    valor = ler_numero("Valor: R$ ")
    data_formatada = ler_data("Data (ex: 23/05/2025, 23-05-2025 ou 23052025): ")

